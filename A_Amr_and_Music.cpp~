#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, k;
    cin >> n >> k;

    vector<int> arr(n);
    for (int i = 0; i < n; i++) cin >> arr[i];

    vector<pair<int,int>> v;  // (difficulty, index)
    for (int i = 0; i < n; i++)
        v.push_back({arr[i], i+1});

    sort(v.begin(), v.end());

    vector<int> ans;
    for (int i = 0; i < n; i++) {
        if (v[i].first <= k) {
            ans.push_back(v[i].second);
            k -= v[i].first;
        } else break;
    }

    cout << ans.size() << "\n";
    for (int x : ans) cout << x << " ";
    return 0;
}
 